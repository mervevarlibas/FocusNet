{
  "name": "focusnet",
  "version": "1.0.0",
  "description": "FocusNet - ders çalışma platformu",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "api": "powershell -ExecutionPolicy Bypass -File ./scripts/start-api.ps1",
    "mobile": "powershell -ExecutionPolicy Bypass -File ./scripts/start-mobile.ps1",
    "dev": "node server.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api",
    "check:mongo": "node scripts/check-mongo.js",
    "list:users": "node scripts/list-users.js",
    "count:dbs": "node scripts/count-all-dbs.js",
    "merge:users": "node scripts/merge-test-users.js",
    "check:redis": "node scripts/check-redis.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0"
  }
}
