# copy .env.example .env

# --- Seçenek 1: Atlas (önerilen — web ile aynı veritabanı) ---
# Atlas → Database → Connect → Drivers → kopyala, sonuna /focusnet ekle
MONGODB_URI=mongodb+srv://KULLANICI:SIFRE@cluster0.mvhcet5.mongodb.net/focusnet?retryWrites=true&w=majority

# --- Seçenek 2: SRV çalışmazsa (querySrv hatası) — Connect → Compass string'deki replicaSet kullan ---
# MONGODB_URI=mongodb://KULLANICI:SIFRE@ac-piz2dze-shard-00-00.mvhcet5.mongodb.net:27017,ac-piz2dze-shard-00-01.mvhcet5.mongodb.net:27017,ac-piz2dze-shard-00-02.mvhcet5.mongodb.net:27017/focusnet?ssl=true&authSource=admin&replicaSet=atlas-w1vs86-shard-0

# --- Seçenek 3: İnternet/Atlas yok — önce: docker compose up -d ---
# MONGODB_URI=mongodb://127.0.0.1:27017/focusnet

JWT_SECRET=uzun-rastgele-gizli-anahtar
PORT=3000

# Redis — docker compose up -d redis veya tam stack
REDIS_URL=redis://127.0.0.1:6379
